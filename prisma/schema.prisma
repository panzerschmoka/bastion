// MotionAI — Prisma Schema
// Turso (libSQL) + NextAuth + Stripe

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ────────────────────────────────────────
// NextAuth.js Models
// ────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ────────────────────────────────────────
// Application Models
// ────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  role          String    @default("USER")
  image         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Stripe subscription fields
  plan                 String    @default("FREE")
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  planExpiresAt        DateTime?

  accounts    Account[]
  sessions    Session[]
  projects    Project[]
  assets      Asset[]
  generations Generation[]
  payments    Payment[]

  @@map("users")
}

model Project {
  id          String        @id @default(cuid())
  title       String
  description String?
  userId      String
  status      String        @default("DRAFT")
  settings    String        @default("{}") // SQLite json string
  thumbnail   String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  videos      Video[]
  assets      Asset[]
  generations Generation[]

  @@index([userId])
  @@map("projects")
}

model Video {
  id                  String   @id @default(cuid())
  projectId           String
  url                 String?
  thumbnailUrl        String?
  duration            Float    @default(0)
  width               Int      @default(1920)
  height              Int      @default(1080)
  fps                 Int      @default(30)
  status              String   @default("DRAFT")
  remotionComposition String   @default("{}") // SQLite json string
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("videos")
}

model Asset {
  id        String    @id @default(cuid())
  projectId String?
  userId    String
  type      String
  filename  String
  url       String
  size      Int       @default(0)
  mimeType  String?
  createdAt DateTime  @default(now())

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([userId])
  @@map("assets")
}

model Generation {
  id             String           @id @default(cuid())
  projectId      String
  userId         String
  prompt         String
  model          String           @default("claude-sonnet-4-20250514")
  inputTokens    Int              @default(0)
  outputTokens   Int              @default(0)
  generatedCode  String?
  status         String           @default("PENDING")
  error          String?
  createdAt      DateTime         @default(now())
  completedAt    DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([userId])
  @@map("generations")
}

// ────────────────────────────────────────
// Payment / Subscription History
// ────────────────────────────────────────

model Payment {
  id                String   @id @default(cuid())
  userId            String
  stripePaymentId   String   @unique
  amount            Int      // in cents
  currency          String   @default("usd")
  status            String   // succeeded, failed, pending
  plan              String   // FREE, PRO, BUSINESS
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("payments")
}
